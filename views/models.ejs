<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%2306B6D4'><path d='M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z'/></svg>">
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="/style.css">
</head>
<body class="text-slate-100 bg-[#030712]">

<%- include('partials/nav', { currentPage: 'models', user: typeof user !== 'undefined' ? user : null }) %>

<div class="hero-bg">
<main class="max-w-5xl mx-auto px-6 py-12 w-full">
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2">模型<span class="gradient-text">目录</span></h1>
    <p class="text-sm text-slate-400">所有可用模型，持续更新接入中</p>
  </div>

  <div class="space-y-8">
    <% providers.filter(p=>p.enabled).forEach(p => { %>
    <div class="glass-card overflow-hidden">
      <div class="px-6 py-4 bg-slate-900/40 border-b border-slate-700/30 flex items-center gap-3">
        <span class="text-lg">🔌</span>
        <div>
          <span class="font-semibold"><%= p.name %></span>
          <code class="ml-2 text-xs text-slate-500 bg-slate-800/60 px-2 py-0.5 rounded"><%= p.id %></code>
        </div>
        <span class="flex-1"></span>
        <span class="text-xs text-cyan-400 bg-cyan-500/10 px-2 py-0.5 rounded-full border border-cyan-500/20"><%= (p.models||[]).length %> 个模型</span>
      </div>
      <div class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% (p.models||[]).forEach(m => { %>
        <div class="p-4 rounded-xl bg-slate-800/40 border border-slate-700/30 hover:border-cyan-500/30 transition">
          <div class="font-mono text-sm text-cyan-300 mb-1"><%= m %></div>
          <div class="text-xs text-slate-500">
            提供商: <%= p.name %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>

  <% if (providers.filter(p=>p.enabled).length === 0) { %>
  <div class="text-center py-20 text-slate-500">
    <div class="text-4xl mb-4">🔌</div>
    <p>暂无可用渠道，管理员正在配置中</p>
  </div>
  <% } %>
</main>

<%- include('partials/footer') %>
</div>
</body>
</html>
