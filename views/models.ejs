<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<script src="https://cdn.tailwindcss.com"></script>
<style>body{background:#0B1120;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}</style>
</head>
<body class="text-slate-100 min-h-screen flex flex-col">

<%- include('partials/nav', { currentPage: 'models', user: typeof user !== 'undefined' ? user : null }) %>

<main class="flex-1 max-w-5xl mx-auto px-6 py-12 w-full">
  <div class="mb-8">
    <h1 class="text-2xl font-bold mb-2">模型目录</h1>
    <p class="text-sm text-slate-400">所有可用模型，持续更新接入中</p>
  </div>

  <div class="space-y-8">
    <% providers.filter(p=>p.enabled).forEach(p => { %>
    <div class="bg-slate-900/50 border border-slate-800 rounded-2xl overflow-hidden">
      <div class="px-6 py-4 bg-slate-900/80 border-b border-slate-800 flex items-center gap-3">
        <span class="text-lg">🔌</span>
        <div>
          <span class="font-semibold"><%= p.name %></span>
          <code class="ml-2 text-xs text-slate-500 bg-slate-800 px-2 py-0.5 rounded"><%= p.id %></code>
        </div>
        <span class="flex-1"></span>
        <span class="text-xs text-cyan-400 bg-cyan-500/10 px-2 py-0.5 rounded-full border border-cyan-500/20"><%= (p.models||[]).length %> 个模型</span>
      </div>
      <div class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% (p.models||[]).forEach(m => { %>
        <div class="p-4 rounded-xl bg-slate-800/50 border border-slate-700/50 hover:border-cyan-700/50 transition">
          <div class="font-mono text-sm text-cyan-300 mb-1"><%= m %></div>
          <div class="text-xs text-slate-500">
            提供商: <%= p.name %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>

  <% if (providers.filter(p=>p.enabled).length === 0) { %>
  <div class="text-center py-20 text-slate-500">
    <div class="text-4xl mb-4">🔌</div>
    <p>暂无可用渠道，管理员正在配置中</p>
  </div>
  <% } %>
</main>

<footer class="border-t border-slate-800 py-6 text-center text-xs text-slate-600">API 中转站 · 完全免费</footer>
</body>
</html>
