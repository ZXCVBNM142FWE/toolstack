<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="在线 PDF 合并工具，免费将多个 PDF 文件合并为一个，完全免费无需注册">
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "PDF 合并",
    "description": "在线免费 PDF 合并工具",
    "url": "https://ijuhe.top/tools/pdf-merge",
    "applicationCategory": "UtilityApplication"
  }
  </script>
</head>
<body>
  <main class="tool-page">
    <div class="tool-header">
      <div class="tool-header-left">
        <span class="tool-header-icon">📄</span>
        <h1>PDF 合并</h1>
      </div>
      <a href="/" class="tool-header-back">← 返回首页</a>
    </div>

<div class="usage-card"><h2>使用说明</h2><ol><li>点击选择 PDF 文件（可多选，最多 20 个）</li><li>文件按文件名排序，列表中可查看文件大小</li><li>点击「合并并下载」按钮，等待服务端处理</li><li>合并完成后自动下载合并后的 PDF 文件</li></ol></div>

    <div class="tool-workspace">
      <div class="tool-panel" style="grid-column:1/-1;">
        <label for="fileInput">选择 PDF 文件（可多选，按文件名排序合并）</label>
        <input type="file" id="fileInput" multiple accept=".pdf" style="margin-top:8px;">
      </div>
      <div class="tool-panel" style="grid-column:1/-1;">
        <label>已选文件</label>
        <ul id="fileList" style="padding:12px;background:#f1f3f5;border:1px solid #dee2e6;border-radius:8px;min-height:80px;list-style:none;font-size:0.9rem;color:#6c757d;">
          <li>尚未选择文件</li>
        </ul>
        <div id="error" class="error-msg"></div>
      </div>

      <div class="tool-actions">
        <button id="mergeBtn" class="btn btn-primary">合并下载</button>
        <button id="clearBtn" class="btn btn-secondary">清空</button>
      </div>
    </div>

  </main>

  <footer class="footer">
    <p>
      <a href="/" style="color:inherit;text-decoration:none;margin:0 8px;">首页</a>
      <span style="margin:0 4px;">·</span>
      <a href="/#toolGrid" style="color:inherit;text-decoration:none;margin:0 8px;">工具列表</a>
      <span style="margin:0 4px;">·</span>
      <a href="mailto:admin@ijuhe.top" style="color:inherit;text-decoration:none;margin:0 8px;">反馈</a>
    </p>
    <p style="margin-top:4px;">用爱发电 · 永不收费</p>
  </footer>

  <script>
    const fileInput = document.getElementById('fileInput');
    const fileList = document.getElementById('fileList');
    const error = document.getElementById('error');

    function hideError() { error.style.display = 'none'; }
    function showError(msg) {
      error.textContent = msg;
      error.style.display = 'block';
    }

    fileInput.addEventListener('change', () => {
      fileList.innerHTML = '';
      if (fileInput.files.length === 0) {
        fileList.innerHTML = '<li>尚未选择文件</li>';
        return;
      }
      Array.from(fileInput.files).forEach(f => {
        const li = document.createElement('li');
        li.textContent = f.name + ' (' + (f.size / 1024).toFixed(1) + ' KB)';
        li.style.cssText = 'color:#212529;padding:2px 0;';
        fileList.appendChild(li);
      });
      hideError();
    });

    document.getElementById('mergeBtn').addEventListener('click', async () => {
      if (fileInput.files.length < 2) {
        showError('请选择至少 2 个 PDF 文件');
        return;
      }

      const formData = new FormData();
      Array.from(fileInput.files).forEach(f => formData.append('pdfs', f));

      try {
        const resp = await fetch('/tools/pdf-merge', { method: 'POST', body: formData });
        if (!resp.ok) {
          const data = await resp.json();
          showError(data.error || '合并失败');
          return;
        }
        const blob = await resp.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'merged.pdf';
        a.click();
        URL.revokeObjectURL(url);
        hideError();
      } catch (e) {
        showError('请求失败: ' + e.message);
      }
    });

    document.getElementById('clearBtn').addEventListener('click', () => {
      fileInput.value = '';
      fileList.innerHTML = '<li>尚未选择文件</li>';
      hideError();
    });
  </script>
</body>
</html>
