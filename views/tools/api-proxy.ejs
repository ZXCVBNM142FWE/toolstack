<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="AI 智能体对话 — 免费免 Key，支持 GPT/Claude/Llama/DeepSeek 等模型">
  <title><%= title %></title>
  <link rel="canonical" href="https://ijuhe.top/tools/api-proxy">
  <link rel="stylesheet" href="/style.css">
  <style>
    .chat-wrap { max-width: 800px; margin: 0 auto; }
    .chat-bar { display: flex; gap: 8px; flex-wrap: wrap; align-items: flex-end; margin-bottom: 12px; }
    .chat-bar select, .chat-bar input { padding: 8px 12px; border: 1px solid #d4d4d8; border-radius: 6px; font-size: 0.88rem; }
    .chat-bar select { min-width: 120px; }
    .tag-free { font-size: 0.68rem; background: #dcfce7; color: #166534; padding: 1px 6px; border-radius: 3px; }
    .tag-paid { font-size: 0.68rem; background: #fef3c7; color: #92400e; padding: 1px 6px; border-radius: 3px; }
    .key-cell { transition: all 0.2s; flex: 1; min-width: 180px; }
    .key-cell.hidden { display: none; }
    .key-cell input { width: 100%; box-sizing: border-box; }
    .chat-log { background: #f8f9fa; border-radius: 10px; padding: 16px; min-height: 400px; max-height: 55vh; overflow-y: auto; margin-bottom: 12px; }
    .msg { margin-bottom: 14px; display: flex; gap: 8px; }
    .msg.user { flex-direction: row-reverse; }
    .msg-avatar { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; flex-shrink: 0; }
    .msg.user .msg-avatar { background: #3b82f6; color: #fff; }
    .msg.bot .msg-avatar { background: #10b981; color: #fff; }
    .msg-bubble { max-width: 78%; padding: 10px 14px; border-radius: 12px; font-size: 0.9rem; line-height: 1.6; white-space: pre-wrap; word-break: break-word; }
    .msg.user .msg-bubble { background: #3b82f6; color: #fff; border-bottom-right-radius: 4px; }
    .msg.bot .msg-bubble { background: #fff; border: 1px solid #e4e4e7; border-bottom-left-radius: 4px; }
    .msg-meta { font-size: 0.7rem; color: #999; margin-top: 2px; }
    .input-row { display: flex; gap: 8px; }
    .input-row textarea { flex: 1; padding: 10px 14px; border: 1px solid #d4d4d8; border-radius: 8px; font-size: 0.9rem; resize: none; min-height: 44px; max-height: 120px; font-family: inherit; }
    .input-row button { padding: 0 20px; border: none; border-radius: 8px; background: #3b82f6; color: #fff; font-weight: 600; cursor: pointer; white-space: nowrap; }
    .input-row button:disabled { opacity: 0.5; cursor: not-allowed; }
    .dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: #aaa; margin: 0 2px; animation: dot-blink 1.4s infinite; }
    .dot:nth-child(2) { animation-delay: 0.2s; }
    .dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes dot-blink { 0%,60%,100% { opacity: 0.3; } 30% { opacity: 1; } }
    .err-bar { color: #e03131; font-size: 0.85rem; padding: 8px 12px; background: #fee2e2; border-radius: 6px; margin-bottom: 10px; display: none; }
    .tip-row { font-size: 0.78rem; color: #666; margin-top: 8px; text-align: center; }
  </style>
</head>
<body>
  <div class="tool-page">
    <h1>AI 智能体对话</h1>

    <div class="chat-wrap">
      <div class="chat-bar">
        <select id="provider" onchange="onProvider()">
          <option value="pollinations">Pollinations<span class="tag-free">免Key</span></option>
          <option value="groq">Groq<span class="tag-free">免费</span></option>
          <option value="deepseek">DeepSeek<span class="tag-free">免费</span></option>
          <option value="gemini">Gemini<span class="tag-free">免费</span></option>
          <option value="anthropic">Claude<span class="tag-paid">付费</span></option>
          <option value="openai">OpenAI<span class="tag-paid">付费</span></option>
        </select>
        <select id="model"></select>
        <div class="key-cell" id="key-cell">
          <input type="password" id="apiKey" placeholder="API Key" autocomplete="off">
        </div>
      </div>

      <div class="err-bar" id="err-bar"></div>

      <div class="chat-log" id="chat-log">
        <div style="text-align:center;color:#999;padding:60px 0;">
          直接开聊，无需任何 API Key 🆓
        </div>
      </div>

      <div class="input-row">
        <textarea id="input" placeholder="输入消息，Enter 发送..." rows="1"
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();send();}"></textarea>
        <button id="send-btn" onclick="send()">发送</button>
      </div>
      <div class="tip-row" id="tip-row">Pollinations.AI · 完全免费 · 无需注册 · 无需 API Key</div>
    </div>

    <a href="/" style="display:block;margin-top:20px;" class="back-link">← 返回首页</a>
  </div>

  <script>
    var messages = [];
    var busy = false;

    var providers = {
      pollinations: {
        models: [
          { v:'openai', label:'GPT-4o Mini' },
          { v:'openai-large', label:'GPT-4o' },
          { v:'claude', label:'Claude Sonnet' },
          { v:'gemini', label:'Gemini 2.5' },
          { v:'llama', label:'Llama 4' },
          { v:'mistral', label:'Mistral' },
          { v:'deepseek', label:'DeepSeek V3' },
          { v:'deepseek-r1', label:'DeepSeek R1' },
          { v:'searchgpt', label:'SearchGPT (联网)' },
        ],
        needKey: false,
        hint: 'Pollinations.AI 提供，完全免费，无需注册'
      },
      groq: {
        models: [
          { v:'llama-4-scout-17b-16e-instruct', label:'Llama 4 Scout' },
          { v:'qwen-3-32b', label:'Qwen 3 32B' },
          { v:'deepseek-r1-distill-llama-70b', label:'DeepSeek R1 70B' },
        ],
        needKey: true,
        hint: 'console.groq.com 免费注册获取 Key'
      },
      deepseek: {
        models: [
          { v:'deepseek-chat', label:'DeepSeek V3' },
          { v:'deepseek-reasoner', label:'DeepSeek R1' },
        ],
        needKey: true,
        hint: 'platform.deepseek.com 注册送 500 万 tokens'
      },
      gemini: {
        models: [
          { v:'gemini-2.5-flash', label:'Gemini 2.5 Flash' },
          { v:'gemini-2.5-pro', label:'Gemini 2.5 Pro' },
        ],
        needKey: true,
        hint: 'aistudio.google.com 免费获取 Key'
      },
      anthropic: {
        models: [
          { v:'claude-sonnet-4-6', label:'Claude Sonnet 4.6' },
          { v:'claude-opus-4-7', label:'Claude Opus 4.7' },
        ],
        needKey: true,
        hint: '需境外信用卡'
      },
      openai: {
        models: [
          { v:'gpt-4o', label:'GPT-4o' },
          { v:'gpt-4o-mini', label:'GPT-4o Mini' },
        ],
        needKey: true,
        hint: '需境外信用卡'
      }
    };

    var savedKey = localStorage.getItem('ai_key');
    var savedProvider = localStorage.getItem('ai_provider') || 'pollinations';
    if (savedKey) document.getElementById('apiKey').value = savedKey;
    document.getElementById('provider').value = savedProvider;
    onProvider();

    function onProvider() {
      var p = document.getElementById('provider').value;
      localStorage.setItem('ai_provider', p);
      var info = providers[p];
      var m = document.getElementById('model');
      m.innerHTML = info.models.map(function(x){ return '<option value="'+x.v+'">'+x.label+'</option>'; }).join('');
      var kc = document.getElementById('key-cell');
      if (info.needKey) { kc.classList.remove('hidden'); }
      else { kc.classList.add('hidden'); }
      document.getElementById('tip-row').textContent = info.hint;
    }

    async function send() {
      var input = document.getElementById('input');
      var text = input.value.trim();
      if (!text || busy) return;

      var provider = document.getElementById('provider').value;
      var info = providers[provider];
      var apiKey = document.getElementById('apiKey').value.trim();

      if (info.needKey && !apiKey) { showErr('请先输入 API Key'); return; }
      if (apiKey) localStorage.setItem('ai_key', apiKey);

      hideErr();
      input.value = ''; input.style.height = 'auto';
      busy = true;
      document.getElementById('send-btn').disabled = true;

      addMsg('user', text);
      messages.push({ role: 'user', content: text });
      var tid = addTyping();

      try {
        var resp = await fetch('/tools/api-proxy/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            provider: provider,
            model: document.getElementById('model').value,
            apiKey: apiKey,
            messages: messages.slice(0, -1),
          })
        });
        var data = await resp.json();
        removeTyping(tid);

        if (data.ok) {
          addMsg('bot', data.content, data.elapsed + ' · ' + data.model);
          messages.push({ role: 'assistant', content: data.content });
        } else {
          addMsg('bot', '❌ ' + data.error, data.elapsed);
          messages.pop();
        }
      } catch (e) {
        removeTyping(tid);
        addMsg('bot', '❌ 网络错误: ' + e.message);
        messages.pop();
      } finally {
        busy = false;
        document.getElementById('send-btn').disabled = false;
      }
    }

    function addMsg(role, content, meta) {
      var el = document.getElementById('chat-log');
      var div = document.createElement('div');
      div.className = 'msg ' + (role === 'user' ? 'user' : 'bot');
      div.innerHTML =
        '<div class="msg-avatar">' + (role === 'user' ? '你' : 'AI') + '</div>' +
        '<div><div class="msg-bubble">' + esc(content) + '</div>' +
        (meta ? '<div class="msg-meta">' + meta + '</div>' : '') + '</div>';
      el.appendChild(div);
      el.scrollTop = el.scrollHeight;
    }

    function addTyping() {
      var el = document.getElementById('chat-log');
      var div = document.createElement('div');
      div.className = 'msg bot';
      div.id = 'typing';
      div.innerHTML = '<div class="msg-avatar">AI</div><div class="msg-bubble"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>';
      el.appendChild(div);
      el.scrollTop = el.scrollHeight;
      return 'typing';
    }

    function removeTyping(id) { var e = document.getElementById(id); if (e) e.remove(); }
    function showErr(m) { var e = document.getElementById('err-bar'); e.textContent = m; e.style.display = 'block'; }
    function hideErr() { document.getElementById('err-bar').style.display = 'none'; }
    function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    document.getElementById('input').addEventListener('input', function() {
      this.style.height = 'auto';
      this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });
  </script>
</body>
</html>
