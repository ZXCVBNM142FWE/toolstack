<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="AI 智能体对话工具，支持 Claude / OpenAI 多模型，服务端代理转发无需 VPN">
  <title><%= title %></title>
  <link rel="canonical" href="https://ijuhe.top/tools/api-proxy">
  <meta property="og:title" content="AI 智能体对话 - 在线 AI 聊天">
  <meta property="og:description" content="支持 Claude / OpenAI，服务端代理转发">
  <meta property="og:type" content="website">
  <link rel="stylesheet" href="/style.css">
  <style>
    .chat-container { max-width: 800px; margin: 0 auto; }
    .chat-config { display: flex; gap: 8px; flex-wrap: wrap; align-items: flex-end; margin-bottom: 16px; }
    .chat-config select, .chat-config input { padding: 8px 12px; border: 1px solid #d4d4d8; border-radius: 6px; font-size: 0.9rem; }
    .chat-config select { width: 120px; }
    .chat-config input { flex: 1; min-width: 200px; }
    .chat-messages { background: #f8f9fa; border-radius: 10px; padding: 16px; min-height: 400px; max-height: 60vh; overflow-y: auto; margin-bottom: 12px; }
    .msg { margin-bottom: 14px; display: flex; gap: 8px; }
    .msg.user { flex-direction: row-reverse; }
    .msg-avatar { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; flex-shrink: 0; }
    .msg.user .msg-avatar { background: #3b82f6; color: #fff; }
    .msg.assistant .msg-avatar { background: #10b981; color: #fff; }
    .msg-bubble { max-width: 80%; padding: 10px 14px; border-radius: 12px; font-size: 0.9rem; line-height: 1.6; white-space: pre-wrap; word-break: break-word; }
    .msg.user .msg-bubble { background: #3b82f6; color: #fff; border-bottom-right-radius: 4px; }
    .msg.assistant .msg-bubble { background: #fff; border: 1px solid #e4e4e7; border-bottom-left-radius: 4px; }
    .msg-meta { font-size: 0.7rem; color: #999; margin-top: 2px; }
    .msg.user .msg-meta { text-align: right; }
    .chat-input-row { display: flex; gap: 8px; }
    .chat-input-row textarea { flex: 1; padding: 10px 14px; border: 1px solid #d4d4d8; border-radius: 8px; font-size: 0.9rem; resize: none; min-height: 44px; max-height: 120px; }
    .chat-input-row button { padding: 0 20px; border: none; border-radius: 8px; background: #3b82f6; color: #fff; font-weight: 600; cursor: pointer; }
    .chat-input-row button:disabled { opacity: 0.5; cursor: not-allowed; }
    .typing-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #999; margin: 0 2px; animation: blink 1.4s infinite; }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes blink { 0%,60%,100% { opacity: 0.3; } 30% { opacity: 1; } }
    .err-msg { color: #e03131; font-size: 0.85rem; padding: 8px 12px; background: #fee2e2; border-radius: 6px; margin-bottom: 10px; display: none; }
    .tip { font-size: 0.8rem; color: #999; margin-top: 8px; text-align: center; }
  </style>
</head>
<body>
  <div class="tool-page">
    <h1>AI 智能体对话</h1>

    <div class="chat-container">
      <div class="chat-config">
        <select id="provider" onchange="onProviderChange()">
          <option value="anthropic">Claude</option>
          <option value="openai">OpenAI</option>
        </select>
        <select id="model">
          <option value="claude-sonnet-4-6">Claude Sonnet 4.6</option>
          <option value="claude-opus-4-7">Claude Opus 4.7</option>
          <option value="claude-haiku-4-5">Claude Haiku 4.5</option>
        </select>
        <input type="password" id="apiKey" placeholder="API Key" autocomplete="off">
      </div>

      <div class="err-msg" id="err-msg"></div>

      <div class="chat-messages" id="chat-messages">
        <div style="text-align:center;color:#999;padding:60px 0;">
          选择一个模型，输入 API Key，开始对话
        </div>
      </div>

      <div class="chat-input-row">
        <textarea id="chat-input" placeholder="输入消息..." rows="1" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMsg();}"></textarea>
        <button id="send-btn" onclick="sendMsg()">发送</button>
      </div>
      <div class="tip">消息仅通过服务器转发，不会存储你的 API Key</div>
    </div>

    <a href="/" style="display:block;margin-top:20px;" class="back-link">← 返回首页</a>
  </div>

  <script>
    var messages = [];
    var chatting = false;

    // Load saved key
    var savedKey = localStorage.getItem('ai_api_key');
    var savedProvider = localStorage.getItem('ai_provider') || 'anthropic';
    if (savedKey) document.getElementById('apiKey').value = savedKey;
    document.getElementById('provider').value = savedProvider;
    onProviderChange();

    function onProviderChange() {
      var p = document.getElementById('provider').value;
      var m = document.getElementById('model');
      localStorage.setItem('ai_provider', p);
      m.innerHTML = p === 'openai'
        ? '<option value="gpt-4o">GPT-4o</option><option value="gpt-4o-mini">GPT-4o Mini</option><option value="o3-mini">o3 Mini</option>'
        : '<option value="claude-sonnet-4-6">Claude Sonnet 4.6</option><option value="claude-opus-4-7">Claude Opus 4.7</option><option value="claude-haiku-4-5">Claude Haiku 4.5</option>';
    }

    async function sendMsg() {
      var input = document.getElementById('chat-input');
      var text = input.value.trim();
      if (!text || chatting) return;

      var apiKey = document.getElementById('apiKey').value.trim();
      if (!apiKey) { showErr('请先输入 API Key'); return; }
      localStorage.setItem('ai_api_key', apiKey);

      hideErr();
      input.value = '';
      input.style.height = 'auto';
      chatting = true;
      document.getElementById('send-btn').disabled = true;

      addMsg('user', text);
      var typingId = addTyping();

      try {
        var resp = await fetch('/tools/api-proxy/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            provider: document.getElementById('provider').value,
            model: document.getElementById('model').value,
            apiKey: apiKey,
            messages: messages,
          })
        });
        var data = await resp.json();

        removeTyping(typingId);

        if (data.ok) {
          addMsg('assistant', data.content, data.elapsed);
        } else {
          addMsg('assistant', '❌ ' + data.error, data.elapsed);
          messages.pop(); // remove failed user msg
        }
      } catch (e) {
        removeTyping(typingId);
        addMsg('assistant', '❌ 网络错误: ' + e.message);
        messages.pop();
      } finally {
        chatting = false;
        document.getElementById('send-btn').disabled = false;
        input.focus();
      }
    }

    function addMsg(role, content, elapsed) {
      messages.push({ role: role, content: content });
      var el = document.getElementById('chat-messages');
      var div = document.createElement('div');
      div.className = 'msg ' + role;
      div.innerHTML =
        '<div class="msg-avatar">' + (role === 'user' ? '你' : 'AI') + '</div>' +
        '<div><div class="msg-bubble">' + esc(content) + '</div>' +
        (elapsed ? '<div class="msg-meta">' + elapsed + '</div>' : '') + '</div>';
      el.appendChild(div);
      el.scrollTop = el.scrollHeight;
    }

    function addTyping() {
      var el = document.getElementById('chat-messages');
      var div = document.createElement('div');
      div.className = 'msg assistant';
      div.id = 'typing-msg';
      div.innerHTML =
        '<div class="msg-avatar">AI</div>' +
        '<div class="msg-bubble"><span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span></div>';
      el.appendChild(div);
      el.scrollTop = el.scrollHeight;
      return 'typing-msg';
    }

    function removeTyping(id) {
      var el = document.getElementById(id);
      if (el) el.remove();
    }

    function showErr(msg) {
      var el = document.getElementById('err-msg');
      el.textContent = msg;
      el.style.display = 'block';
    }

    function hideErr() {
      document.getElementById('err-msg').style.display = 'none';
    }

    function esc(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // Auto-resize textarea
    document.getElementById('chat-input').addEventListener('input', function() {
      this.style.height = 'auto';
      this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });
  </script>
</body>
</html>
