п»ҝ<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>рҹӣ пёҸ</text></svg>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="йҚҰг„§еҡҺ JSON йҸҚз…ҺзҙЎйҚ–ж §дјҗйҚҸеҮӨзҙқйҸҖоҲӣеҜ” JSON йҸҚз…ҺзҙЎйҚ–ж ҘвӮ¬дҪёеёҮзјӮв•ҒжӢ°жҘ еІғзҳүй”ӣеұҪз•¬йҚҸг„ҘеҺӨз’җи§„жЈӨй—ҮвӮ¬еЁүг„Ҙе”Ҫ">
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JSON йҸҚз…ҺзҙЎйҚ–?,
    "description": "йҚҰг„§еҡҺ JSON йҸҚз…ҺзҙЎйҚ–ж ҘвӮ¬дҪёеёҮзјӮв”ҝвӮ¬дҫҖзҚҷз’ҮдҪёдјҗйҚҸ?,
    "url": "https://ijuhe.top/tools/json-formatter",
    "applicationCategory": "UtilityApplication"
  }
  </script>
</head>
<body>
  <main class="tool-page">
    <div class="tool-header">
      <div class="tool-header-left">
        <span class="tool-header-icon">йҰғж•Ў</span>
        <h1>JSON йҸҚз…ҺзҙЎйҚ–?/h1>
      </div>
      <a href="/" class="tool-header-back">йҲ«?жқ©ж–ҝжҙ–жЈЈж ӯгҖү</a>
    </div>

<div class="usage-card"><h2>жөЈи·Ёж•Өз’Үеӯҳж§‘</h2><ol><li>йҚҰг„Ҙд№ҸжёҡСҶз·ӯйҚҸгғҰо”Ӣж¶“о… зҹҳз’җ?JSON зҖӣжҘғоғҒж¶“?/li><li>йҗҗз‘°еҡ®йҠҶеұҫзүёеҜ®еҝ“еҜІйҠҶе¶ҶеҜңй–ҪоҶҫз·ЁйҚ–?JSONй”ӣеұҫеһЁйҗҗз‘°еҡ®йҠҶеұҪеёҮзјӮв”ҝвӮ¬е¶…е№“й—„гӮ…оҳҝжөЈж¬‘в”–йҸҚ?/li><li>йҚҷе……жҷ¶й—ҲгҲЎжҫҳйҸ„еү§гҒҡжҫ¶еӢӯжӮҠзјҒж’ҙзҒүй”ӣеұҪоӣ§йҸҲеӨҺоҮўеЁүжӣўж•Ҡз’ҮоҲҷзҙ°йҸҚеӣ©еӯ©йҺ»ж„®гҒҡ</li><li>йҗҗз‘°еҡ®йҠҶеұҫз«»з»ҢжҒ’вӮ¬е¶ҶеҜңй–ҪоҮҖеҷёзјғоҶҝз·ӯйҚҸгғҘжӢ°жқҲж’іеҡӯ</li></ol></div>

    <div class="tool-workspace">
      <div class="tool-panel">
        <label for="input">жқҲж’іеҸҶ</label>
        <textarea id="input" placeholder='{"hello":"world"}'></textarea>
      </div>
      <div class="tool-panel">
        <label for="output">жқҲж’іеҡӯ</label>
        <pre id="output"></pre>
        <div id="error" class="error-msg"></div>
      </div>

      <div class="tool-actions">
        <button id="formatBtn" class="btn btn-primary">йҸҚз…ҺзҙЎйҚ–?/button>
        <button id="compressBtn" class="btn btn-secondary">йҚҳе¬¬зјү</button>
        <button id="clearBtn" class="btn btn-secondary">еЁ“е‘Ҝв”–</button>
      </div>
    </div>

  </main>

  <footer class="footer">
    <p>
      <a href="/" style="color:inherit;text-decoration:none;margin:0 8px;">жЈЈж ӯгҖү</a>
      <span style="margin:0 4px;">и·Ҝ</span>
      <a href="/#toolGrid" style="color:inherit;text-decoration:none;margin:0 8px;">е®ёгғҘеҸҝйҚ’жҘ„гҖғ</a>
      <span style="margin:0 4px;">и·Ҝ</span>
      <a href="mailto:admin@ijuhe.top" style="color:inherit;text-decoration:none;margin:0 8px;">йҚҷе¶үоӣӯ</a>
    </p>
    <p style="margin-top:4px;">йҗўг„§еҹҚйҚҷжҲ ж•ё и·Ҝ е§ҳй•җз¬үйҸҖжғ°еһӮ</p>
  </footer>

  <script>
    const input = document.getElementById('input');
    const output = document.getElementById('output');
    const error = document.getElementById('error');

    function hideError() { error.style.display = 'none'; }
    function showError(msg) {
      error.textContent = msg;
      error.style.display = 'block';
      output.textContent = '';
    }

    document.getElementById('formatBtn').addEventListener('click', () => {
      try {
        const obj = JSON.parse(input.value);
        output.textContent = JSON.stringify(obj, null, 2);
        hideError();
      } catch (e) {
        showError('JSON йҸҚз…ҺзҙЎй–ҝж¬’оҮӨ: ' + e.message);
      }
    });

    document.getElementById('compressBtn').addEventListener('click', () => {
      try {
        const obj = JSON.parse(input.value);
        output.textContent = JSON.stringify(obj);
        hideError();
      } catch (e) {
        showError('JSON йҸҚз…ҺзҙЎй–ҝж¬’оҮӨ: ' + e.message);
      }
    });

    document.getElementById('clearBtn').addEventListener('click', () => {
      input.value = '';
      output.textContent = '';
      hideError();
    });
  </script>
</body>
</html>
