<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="在线 JSON 格式化工具，支持 JSON 格式化、压缩和验证，完全免费无需注册">
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JSON 格式化",
    "description": "在线 JSON 格式化、压缩、验证工具",
    "url": "https://ijuhe.top/tools/json-formatter",
    "applicationCategory": "UtilityApplication"
  }
  </script>
</head>
<body>
  <main class="tool-page">
    <h1>JSON 格式化</h1>

    <div class="tool-workspace">
      <div class="tool-panel">
        <label for="input">输入</label>
        <textarea id="input" placeholder='{"hello":"world"}'></textarea>
      </div>
      <div class="tool-panel">
        <label for="output">输出</label>
        <pre id="output"></pre>
        <div id="error" class="error-msg"></div>
      </div>

      <div class="tool-actions">
        <button id="formatBtn" class="btn btn-primary">格式化</button>
        <button id="compressBtn" class="btn btn-secondary">压缩</button>
        <button id="clearBtn" class="btn btn-secondary">清空</button>
      </div>
    </div>

    <a href="/" class="back-link">← 返回首页</a>
  </main>

  <script>
    const input = document.getElementById('input');
    const output = document.getElementById('output');
    const error = document.getElementById('error');

    function hideError() { error.style.display = 'none'; }
    function showError(msg) {
      error.textContent = msg;
      error.style.display = 'block';
      output.textContent = '';
    }

    document.getElementById('formatBtn').addEventListener('click', () => {
      try {
        const obj = JSON.parse(input.value);
        output.textContent = JSON.stringify(obj, null, 2);
        hideError();
      } catch (e) {
        showError('JSON 格式错误: ' + e.message);
      }
    });

    document.getElementById('compressBtn').addEventListener('click', () => {
      try {
        const obj = JSON.parse(input.value);
        output.textContent = JSON.stringify(obj);
        hideError();
      } catch (e) {
        showError('JSON 格式错误: ' + e.message);
      }
    });

    document.getElementById('clearBtn').addEventListener('click', () => {
      input.value = '';
      output.textContent = '';
      hideError();
    });
  </script>
</body>
</html>
