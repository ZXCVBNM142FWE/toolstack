п»ҝ<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>рҹӣ пёҸ</text></svg>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="йҚҰг„§еҡҺйҚҘеү§еў–йҚҳе¬¬зјүе®ёгғҘеҸҝй”ӣеұҪеҺӨз’җз‘°еёҮзјӮ?PNG/JPEG йҚҘеү§еў–й”ӣеұҪз•¬йҚҸг„ҘеҺӨз’җи§„жЈӨй—ҮвӮ¬еЁүг„Ҙе”Ҫ">
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "йҚҘеү§еў–йҚҳе¬¬зјү",
    "description": "йҚҰг„§еҡҺйҚҘеү§еў–йҚҳе¬¬зјүе®ёгғҘеҸҝй”ӣеұҫж•®йҺё?PNG/JPEG",
    "url": "https://ijuhe.top/tools/image-compress",
    "applicationCategory": "UtilityApplication"
  }
  </script>
</head>
<body>
  <main class="tool-page">
    <div class="tool-header">
      <div class="tool-header-left">
        <span class="tool-header-icon">йҰғжҹӨй””?/span>
        <h1>йҚҘеү§еў–йҚҳе¬¬зјү</h1>
      </div>
      <a href="/" class="tool-header-back">йҲ«?жқ©ж–ҝжҙ–жЈЈж ӯгҖү</a>
    </div>

<div class="usage-card"><h2>жөЈи·Ёж•Өз’Үеӯҳж§‘</h2><ol><li>йҗҗз‘°еҡ®й–«еӨӢе«Ёй—ҮвӮ¬з‘•дҪёеёҮзјӮв•ғж®‘йҚҘеү§еў–й”ӣе ҹж•®йҺё?PNG/JPEG з»ӣеӨҠзҲ¶з‘ҷдҪ№зүёеҜ®еҝҘзҙҡ</li><li>йҺ·ж §е§©з’җг„©еҷәе©ҠжҲқжҪЎз’ӢеҶӯеҰӯйҚҳе¬¬зјүе§Јж–ҫз·Ҙй”ӣе ҘзІҜз’Ғ?80%й”ӣеІғз§әжөЈеәўжһғжө жғ°з§әзҒҸеҝҺзөҫйҗўжҳҸе·қз“’е©ӮжЁҠй”ӣ?/li><li>йҗҗз‘°еҡ®йҠҶеұҪеёҮзјӮв•ҒиӢҹж¶“е¬ӯжөҮйҠҶе¶ҶеҜңй–ҪоҮҶзҙқз»ӣеӨҠз·ҹйҸҲе¶…е§ҹз»”оҲҡоҳ©йҗһ?/li><li>йҚҳе¬¬зјүзҖ№еұҫеһҡйҚҡеәӨеҡңйҚ”г„Өз¬…жқһж–ӨзҙқжӨӨз”ёжҪ°йҚҡеұҫжӨӮйҸ„еү§гҒҡйҚҳзҶ·жөҳйҚңеұҪеёҮзјӮв•ҒжӮ—йҗЁеӢ«оҮ®е§Ј?/li></ol></div>

    <div class="tool-workspace">
      <div class="tool-panel" style="grid-column:1/-1;">
        <label for="fileInput">й–«еӨӢе«ЁйҚҘеү§еў–</label>
        <input type="file" id="fileInput" accept="image/*" style="margin-top:8px;">
      </div>
      <div class="tool-panel">
        <label>йҚҳзҶ·жөҳ</label>
        <div style="flex:1;min-height:200px;display:flex;align-items:center;justify-content:center;background:#f1f3f5;border:1px solid #dee2e6;border-radius:8px;overflow:hidden;">
          <img id="originalPreview" style="max-width:100%;max-height:200px;display:none;">
          <span id="noPreview" style="color:#adb5bd;">жЈ°еӢ®оқҚ</span>
        </div>
        <div id="originalSize" style="font-size:0.85rem;color:#6c757d;margin-top:4px;"></div>
      </div>
      <div class="tool-panel">
        <label>йҚҳе¬¬зјүйҚҡ?/label>
        <div style="flex:1;min-height:200px;display:flex;align-items:center;justify-content:center;background:#f1f3f5;border:1px solid #dee2e6;border-radius:8px;overflow:hidden;">
          <img id="compressedPreview" style="max-width:100%;max-height:200px;display:none;">
          <span id="noCompressed" style="color:#adb5bd;">йҗҗз‘°еҡ®йҚҳе¬¬зјү</span>
        </div>
        <div id="compressedSize" style="font-size:0.85rem;color:#6c757d;margin-top:4px;"></div>
      </div>

      <div class="tool-panel" style="grid-column:1/-1;">
        <label for="quality">з’җг„©еҷә: <span id="qualityVal">80</span></label>
        <input type="range" id="quality" min="1" max="100" value="80" style="width:100%;">
      </div>

      <div class="tool-actions">
        <button id="compressBtn" class="btn btn-primary">йҚҳе¬¬зјүж¶“е¬ӯжөҮ</button>
        <button id="clearBtn" class="btn btn-secondary">еЁ“е‘Ҝв”–</button>
      </div>

      <div id="error" class="error-msg" style="grid-column:1/-1;"></div>
    </div>

  </main>

  <footer class="footer">
    <p>
      <a href="/" style="color:inherit;text-decoration:none;margin:0 8px;">жЈЈж ӯгҖү</a>
      <span style="margin:0 4px;">и·Ҝ</span>
      <a href="/#toolGrid" style="color:inherit;text-decoration:none;margin:0 8px;">е®ёгғҘеҸҝйҚ’жҘ„гҖғ</a>
      <span style="margin:0 4px;">и·Ҝ</span>
      <a href="mailto:admin@ijuhe.top" style="color:inherit;text-decoration:none;margin:0 8px;">йҚҷе¶үоӣӯ</a>
    </p>
    <p style="margin-top:4px;">йҗўг„§еҹҚйҚҷжҲ ж•ё и·Ҝ е§ҳй•җз¬үйҸҖжғ°еһӮ</p>
  </footer>

  <script>
    const fileInput = document.getElementById('fileInput');
    const quality = document.getElementById('quality');
    const originalPreview = document.getElementById('originalPreview');
    const compressedPreview = document.getElementById('compressedPreview');
    const error = document.getElementById('error');

    function hideError() { error.style.display = 'none'; }
    function showError(msg) {
      error.textContent = msg;
      error.style.display = 'block';
    }

    quality.addEventListener('input', () => {
      document.getElementById('qualityVal').textContent = quality.value;
    });

    fileInput.addEventListener('change', () => {
      if (!fileInput.files[0]) return;
      const url = URL.createObjectURL(fileInput.files[0]);
      originalPreview.src = url;
      originalPreview.style.display = '';
      document.getElementById('noPreview').style.display = 'none';
      document.getElementById('originalSize').textContent = 'йҚҳзҶ·жөҳ: ' + (fileInput.files[0].size / 1024).toFixed(1) + ' KB';
      compressedPreview.style.display = 'none';
      document.getElementById('noCompressed').style.display = '';
      document.getElementById('compressedSize').textContent = '';
      hideError();
    });

    document.getElementById('compressBtn').addEventListener('click', async () => {
      if (!fileInput.files[0]) {
        showError('з’ҮзғҪвӮ¬еӨӢе«Ёж¶“вӮ¬еҜ®зҠІжөҳйҗ—?);
        return;
      }

      const formData = new FormData();
      formData.append('image', fileInput.files[0]);
      formData.append('quality', quality.value);

      try {
        const resp = await fetch('/tools/image-compress', { method: 'POST', body: formData });
        if (!resp.ok) {
          const data = await resp.json();
          showError(data.error || 'йҚҳе¬¬зјүжҫ¶иҫ«и§Ұ');
          return;
        }
        const result = await resp.json();
        document.getElementById('compressedSize').textContent =
          'йҚҳе¬¬зјүйҚҡ? ' + (result.compressed / 1024).toFixed(1) + ' KB (' +
          (100 - result.compressed / result.original * 100).toFixed(1) + '% йҚ‘еҝ“зҡ¬)';

        const byteString = atob(result.data);
        const bytes = new Uint8Array(byteString.length);
        for (let i = 0; i < byteString.length; i++) bytes[i] = byteString.charCodeAt(i);
        const blob = new Blob([bytes], { type: result.type });

        const url = URL.createObjectURL(blob);
        compressedPreview.src = url;
        compressedPreview.style.display = '';
        document.getElementById('noCompressed').style.display = 'none';

        const a = document.createElement('a');
        a.href = url;
        a.download = 'compressed.' + (result.type === 'image/png' ? 'png' : 'jpg');
        a.click();

        hideError();
      } catch (e) {
        showError('з’Үй”Ӣзң°жҫ¶иҫ«и§Ұ: ' + e.message);
      }
    });

    document.getElementById('clearBtn').addEventListener('click', () => {
      fileInput.value = '';
      originalPreview.style.display = 'none';
      document.getElementById('noPreview').style.display = '';
      document.getElementById('originalSize').textContent = '';
      compressedPreview.style.display = 'none';
      document.getElementById('noCompressed').style.display = '';
      document.getElementById('compressedSize').textContent = '';
      hideError();
    });
  </script>
</body>
</html>
