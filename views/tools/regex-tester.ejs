<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛠️</text></svg>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="鍦ㄧ嚎姝ｅ垯琛ㄨ揪寮忔祴璇曞伐鍏凤紝鏀寔 g/i/m 淇グ绗︼紝楂樹寒鍖归厤缁撴灉锛屽畬鍏ㄥ厤璐?>
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "姝ｅ垯琛ㄨ揪寮忔祴璇?,
    "description": "鍦ㄧ嚎姝ｅ垯琛ㄨ揪寮忔祴璇曡皟璇曞伐鍏?,
    "url": "https://ijuhe.top/tools/regex-tester",
    "applicationCategory": "UtilityApplication"
  }
  </script>
</head>
<body class="text-slate-100 bg-[#030712]">
<%- include('../partials/nav', { currentPage: 'tools', user: typeof user !== 'undefined' ? user : null }) %>
<div class="hero-bg">
  <main class="tool-page">
    <div class="tool-header">
      <div class="tool-header-left">
        <span class="tool-header-icon">馃攳</span>
        <h1>姝ｅ垯琛ㄨ揪寮忔祴璇?/h1>
      </div>
      <a href="/" class="tool-header-back">鈫?杩斿洖棣栭〉</a>
    </div>

<div class="usage-card"><h2>浣跨敤璇存槑</h2><ol><li>鍦ㄣ€屾鍒欒〃杈惧紡銆嶈緭鍏ユ涓緭鍏ユ鍒欐ā寮忥紙濡?<code>d{4}-d{2}-d{2}</code>锛?/li><li>鍕鹃€夐渶瑕佺殑鏍囧織浣嶏細g锛堝叏灞€锛夈€乮锛堝拷鐣ュぇ灏忓啓锛夈€乵锛堝琛岋級</li><li>鍦ㄣ€屾祴璇曟枃鏈€嶆涓矘璐村緟鍖归厤鐨勫唴瀹?/li><li>鐐瑰嚮銆屾祴璇曘€嶆煡鐪嬪尮閰嶇粨鏋滐紝鍖归厤椤逛細楂樹寒鏄剧ず</li></ol></div>

    <div class="tool-workspace">
      <div class="tool-panel">
        <label for="pattern">姝ｅ垯琛ㄨ揪寮?/label>
        <input type="text" id="pattern" placeholder="渚嬪: \d{4}-\d{2}-\d{2}" style="padding:10px;border:1px solid #dee2e6;border-radius:8px;font-family:monospace;">
        <div style="margin-top:8px;display:flex;gap:16px;">
          <label style="font-weight:400;"><input type="checkbox" id="flagG" checked> 鍏ㄥ眬 (g)</label>
          <label style="font-weight:400;"><input type="checkbox" id="flagI"> 蹇界暐澶у皬鍐?(i)</label>
          <label style="font-weight:400;"><input type="checkbox" id="flagM"> 澶氳 (m)</label>
        </div>
      </div>
      <div class="tool-panel">
        <label for="input">娴嬭瘯鏂囨湰</label>
        <textarea id="input" placeholder="杈撳叆瑕佹祴璇曠殑鏂囨湰..."></textarea>
      </div>
      <div class="tool-panel">
        <label>鍖归厤缁撴灉</label>
        <div id="output" style="flex:1;min-height:360px;padding:12px;background:#f1f3f5;border:1px solid #dee2e6;border-radius:8px;overflow-y:auto;font-family:monospace;font-size:0.85rem;white-space:pre-wrap;"></div>
        <div id="error" class="error-msg"></div>
      </div>

      <div class="tool-actions">
        <button id="testBtn" class="btn btn-primary">娴嬭瘯</button>
        <button id="clearBtn" class="btn btn-secondary">娓呯┖</button>
      </div>
    </div>

  </main>

  <%- include('../partials/footer') %>
</div>

  <script>
    const pattern = document.getElementById('pattern');
    const input = document.getElementById('input');
    const output = document.getElementById('output');
    const error = document.getElementById('error');

    function hideError() { error.style.display = 'none'; }
    function showError(msg) {
      error.textContent = msg;
      error.style.display = 'block';
      output.innerHTML = '';
    }

    document.getElementById('testBtn').addEventListener('click', () => {
      try {
        let flags = '';
        if (document.getElementById('flagG').checked) flags += 'g';
        if (document.getElementById('flagI').checked) flags += 'i';
        if (document.getElementById('flagM').checked) flags += 'm';

        const re = new RegExp(pattern.value, flags);
        const escaped = input.value.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        const result = escaped.replace(re, (match) => '<mark>' + match + '</mark>');
        output.innerHTML = result || '鏃犲尮閰?;
        hideError();
      } catch (e) {
        showError('姝ｅ垯琛ㄨ揪寮忛敊璇? ' + e.message);
      }
    });

    document.getElementById('clearBtn').addEventListener('click', () => {
      pattern.value = '';
      input.value = '';
      output.innerHTML = '';
      hideError();
    });
  </script>
</body>
</html>
