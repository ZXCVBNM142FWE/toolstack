<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%2306B6D4'><path d='M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z'/></svg>">
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="/style.css">
</head>
<body class="text-slate-100 bg-[#030712]">

<%- include('partials/nav', { currentPage: 'login', user: typeof user !== 'undefined' ? user : null }) %>

<div class="hero-bg relative overflow-hidden">
  <div class="relative z-10 min-h-[90vh] flex items-center justify-center p-6">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2 text-2xl no-underline group">
          <span class="w-10 h-10 rounded-xl bg-cyan-500/15 flex items-center justify-center text-xl group-hover:bg-cyan-500/25 transition">⚡</span>
          <span class="gradient-text font-extrabold">API 中转站</span>
        </a>
        <p class="text-sm text-slate-400 mt-3">重置密码</p>
      </div>

      <div class="glass-card rounded-2xl p-6">
        <% if (typeof error !== 'undefined' && error) { %>
        <div id="errorBox" class="p-3 bg-red-500/10 border border-red-500/20 rounded-xl text-sm text-red-400 mb-4"><%= error %></div>
        <% } %>
        <div id="msgBox" class="p-3 bg-green-500/10 border border-green-500/20 rounded-xl text-sm text-green-400 mb-4" style="display:none"></div>

        <div id="step1" class="space-y-4">
          <label class="block text-xs text-slate-400 mb-1.5 ml-1">注册邮箱</label>
          <input id="email" type="email" placeholder="your@email.com" required class="w-full px-4 py-3 bg-slate-900/50 border border-slate-700/50 rounded-xl text-slate-200 text-sm placeholder-slate-500 outline-none focus:border-cyan-500/50 focus:ring-2 focus:ring-cyan-500/10 transition backdrop-blur">
          <button id="sendBtn" onclick="sendCode()" class="btn-glow w-full py-3 bg-gradient-to-r from-cyan-500 to-blue-500 text-white rounded-xl font-bold text-sm hover:from-cyan-400 hover:to-blue-400 transition cursor-pointer shadow-xl shadow-cyan-500/25">发送验证码</button>
        </div>

        <div id="step2" class="space-y-4" style="display:none">
          <p class="text-xs text-slate-500">验证码已发送到 <span id="emailDisplay" class="text-cyan-400 font-medium"></span></p>
          <input id="code" type="text" maxlength="6" placeholder="6 位验证码" required class="w-full px-4 py-3 bg-slate-900/50 border border-slate-700/50 rounded-xl text-slate-200 text-sm placeholder-slate-500 outline-none focus:border-cyan-500/50 focus:ring-2 focus:ring-cyan-500/10 transition backdrop-blur tracking-[0.3em] text-center text-lg font-mono">
          <input id="newPassword" type="password" placeholder="新密码（至少 6 位）" required minlength="6" class="w-full px-4 py-3 bg-slate-900/50 border border-slate-700/50 rounded-xl text-slate-200 text-sm placeholder-slate-500 outline-none focus:border-cyan-500/50 focus:ring-2 focus:ring-cyan-500/10 transition backdrop-blur">
          <button id="resetBtn" onclick="resetPassword()" class="btn-glow w-full py-3 bg-gradient-to-r from-cyan-500 to-blue-500 text-white rounded-xl font-bold text-sm hover:from-cyan-400 hover:to-blue-400 transition cursor-pointer shadow-xl shadow-cyan-500/25">重置密码</button>
          <button onclick="goBack()" class="w-full py-2 bg-transparent text-slate-500 rounded-xl text-sm hover:text-slate-300 transition cursor-pointer border-0">← 重新填写邮箱</button>
        </div>
      </div>

      <p class="text-center text-sm text-slate-500 mt-6">
        <a href="/login" class="text-cyan-400 hover:text-cyan-300 transition">← 返回登录</a>
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<button id="backToTop" class="fixed bottom-8 right-8 w-12 h-12 bg-cyan-500/20 border border-cyan-500/30 text-cyan-400 rounded-full shadow-lg hover:bg-cyan-500/30 transition-all duration-200 opacity-0 pointer-events-none cursor-pointer flex items-center justify-center z-50 backdrop-blur text-lg">↑</button>

<script>
const btnTop = document.getElementById('backToTop');
window.addEventListener('scroll', () => {
  const v = window.scrollY > 400;
  btnTop.style.opacity = v ? '1' : '0';
  btnTop.style.pointerEvents = v ? 'auto' : 'none';
});
btnTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

const emailEl = document.getElementById("email");
const sendBtn = document.getElementById("sendBtn");
const msgBox = document.getElementById("msgBox");
const errorBox = document.getElementById("errorBox");
let cooldown = 0;

function showMsg(text, isError) {
  const box = isError ? errorBox : msgBox;
  box.textContent = text;
  box.style.display = "block";
  if (!isError) errorBox.style.display = "none";
  if (isError) msgBox.style.display = "none";
}

async function sendCode() {
  const email = emailEl.value.trim();
  if (!email) return showMsg("请输入邮箱", true);

  sendBtn.disabled = true;
  sendBtn.textContent = "发送中...";

  try {
    const res = await fetch("/forgot-password/send-code", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email }),
    });
    const data = await res.json();
    if (data.ok) {
      document.getElementById("emailDisplay").textContent = email;
      document.getElementById("step1").style.display = "none";
      document.getElementById("step2").style.display = "";
      showMsg("验证码已发送，请查收邮件", false);
      startCooldown();
    } else {
      showMsg(data.error, true);
      sendBtn.disabled = false;
      sendBtn.textContent = "发送验证码";
    }
  } catch (e) {
    showMsg("网络错误，请稍后再试", true);
    sendBtn.disabled = false;
    sendBtn.textContent = "发送验证码";
  }
}

function startCooldown() {
  cooldown = 60;
  sendBtn.disabled = true;
  const tick = () => {
    if (cooldown <= 0) {
      sendBtn.disabled = false;
      sendBtn.textContent = "重新发送";
      return;
    }
    sendBtn.textContent = cooldown + " 秒后可重发";
    cooldown--;
    setTimeout(tick, 1000);
  };
  tick();
}

function goBack() {
  document.getElementById("step1").style.display = "";
  document.getElementById("step2").style.display = "none";
  errorBox.style.display = "none";
  msgBox.style.display = "none";
}

async function resetPassword() {
  const code = document.getElementById("code").value.trim();
  const newPassword = document.getElementById("newPassword").value;
  if (code.length !== 6) return showMsg("请输入 6 位验证码", true);
  if (newPassword.length < 6) return showMsg("新密码至少 6 位", true);

  const resetBtn = document.getElementById("resetBtn");
  resetBtn.disabled = true;
  resetBtn.textContent = "重置中...";

  try {
    const res = await fetch("/forgot-password/reset", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ code, password: newPassword }),
    });
    const data = await res.json();
    if (data.ok) {
      showMsg("密码重置成功！3 秒后跳转到登录页...", false);
      setTimeout(() => { window.location.href = data.redirect || "/login"; }, 3000);
    } else {
      showMsg(data.error, true);
      resetBtn.disabled = false;
      resetBtn.textContent = "重置密码";
    }
  } catch (e) {
    showMsg("网络错误", true);
    resetBtn.disabled = false;
    resetBtn.textContent = "重置密码";
  }
}
</script>
</body>
</html>
