<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<script src="https://cdn.tailwindcss.com"></script>
<style>body{background:#0B1120;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}</style>
</head>
<body class="text-slate-100 min-h-screen flex items-center justify-center p-6">

<div class="w-full max-w-sm">
  <div class="text-center mb-8">
    <a href="/" class="text-2xl font-bold text-cyan-400 no-underline">⚡ API 中转站</a>
    <p class="text-sm text-slate-400 mt-2">重置密码</p>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
  <div id="errorBox" class="p-3 bg-red-900/30 border border-red-800 rounded-xl text-sm text-red-300 mb-4"><%= error %></div>
  <% } %>
  <div id="msgBox" class="p-3 bg-green-900/30 border border-green-800 rounded-xl text-sm text-green-300 mb-4" style="display:none"></div>

  <!-- Step 1: 输入邮箱，发送验证码 -->
  <div id="step1" class="space-y-4">
    <input id="email" type="email" placeholder="注册邮箱" required class="w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-xl text-slate-200 text-sm focus:ring-2 focus:ring-cyan-500 outline-none">
    <button id="sendBtn" onclick="sendCode()" class="w-full py-3 bg-cyan-600 text-white rounded-xl font-semibold text-sm hover:bg-cyan-500 transition cursor-pointer">发送验证码</button>
  </div>

  <!-- Step 2: 输入验证码 + 新密码 -->
  <div id="step2" class="space-y-4" style="display:none">
    <p class="text-xs text-slate-500">验证码已发送到 <span id="emailDisplay" class="text-cyan-400"></span></p>
    <input id="code" type="text" maxlength="6" placeholder="6 位验证码" required class="w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-xl text-slate-200 text-sm focus:ring-2 focus:ring-cyan-500 outline-none tracking-widest text-center">
    <input id="newPassword" type="password" placeholder="新密码（至少 6 位）" required minlength="6" class="w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-xl text-slate-200 text-sm focus:ring-2 focus:ring-cyan-500 outline-none">
    <button id="resetBtn" onclick="resetPassword()" class="w-full py-3 bg-cyan-600 text-white rounded-xl font-semibold text-sm hover:bg-cyan-500 transition cursor-pointer">重置密码</button>
    <button onclick="goBack()" class="w-full py-2 bg-transparent text-slate-500 rounded-xl text-sm hover:text-slate-300 transition cursor-pointer">重新填写邮箱</button>
  </div>

  <p class="text-center text-sm text-slate-500 mt-4">
    <a href="/login" class="text-cyan-400 hover:text-cyan-300 transition">返回登录</a>
  </p>
</div>

<script>
const emailEl = document.getElementById("email");
const sendBtn = document.getElementById("sendBtn");
const msgBox = document.getElementById("msgBox");
const errorBox = document.getElementById("errorBox");
let cooldown = 0;

function showMsg(text, isError) {
  const box = isError ? errorBox : msgBox;
  box.textContent = text;
  box.style.display = "block";
  if (!isError) errorBox.style.display = "none";
  if (isError) msgBox.style.display = "none";
}

async function sendCode() {
  const email = emailEl.value.trim();
  if (!email) return showMsg("请输入邮箱", true);

  sendBtn.disabled = true;
  sendBtn.textContent = "发送中...";

  try {
    const res = await fetch("/forgot-password/send-code", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email }),
    });
    const data = await res.json();
    if (data.ok) {
      document.getElementById("emailDisplay").textContent = email;
      document.getElementById("step1").style.display = "none";
      document.getElementById("step2").style.display = "";
      showMsg("验证码已发送，请查收邮件", false);
      startCooldown();
    } else {
      showMsg(data.error, true);
      sendBtn.disabled = false;
      sendBtn.textContent = "发送验证码";
    }
  } catch (e) {
    showMsg("网络错误，请稍后再试", true);
    sendBtn.disabled = false;
    sendBtn.textContent = "发送验证码";
  }
}

function startCooldown() {
  cooldown = 60;
  sendBtn.disabled = true;
  const tick = () => {
    if (cooldown <= 0) {
      sendBtn.disabled = false;
      sendBtn.textContent = "重新发送";
      return;
    }
    sendBtn.textContent = `${cooldown} 秒后可重发`;
    cooldown--;
    setTimeout(tick, 1000);
  };
  tick();
}

function goBack() {
  document.getElementById("step1").style.display = "";
  document.getElementById("step2").style.display = "none";
  errorBox.style.display = "none";
  msgBox.style.display = "none";
}

async function resetPassword() {
  const code = document.getElementById("code").value.trim();
  const newPassword = document.getElementById("newPassword").value;
  if (code.length !== 6) return showMsg("请输入 6 位验证码", true);
  if (newPassword.length < 6) return showMsg("新密码至少 6 位", true);

  const resetBtn = document.getElementById("resetBtn");
  resetBtn.disabled = true;
  resetBtn.textContent = "重置中...";

  try {
    const res = await fetch("/forgot-password/reset", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ code, password: newPassword }),
    });
    const data = await res.json();
    if (data.ok) {
      showMsg("密码重置成功！3 秒后跳转到登录页...", false);
      setTimeout(() => { window.location.href = data.redirect || "/login"; }, 3000);
    } else {
      showMsg(data.error, true);
      resetBtn.disabled = false;
      resetBtn.textContent = "重置密码";
    }
  } catch (e) {
    showMsg("网络错误", true);
    resetBtn.disabled = false;
    resetBtn.textContent = "重置密码";
  }
}
</script>

</body>
</html>
