<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%2306B6D4'><path d='M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z'/></svg>">
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="/style.css">
</head>
<body class="text-slate-100 bg-[#030712]">

<%- include('partials/nav', { currentPage: 'login', user: typeof user !== 'undefined' ? user : null }) %>

<div class="hero-bg relative overflow-hidden">
  <div class="relative z-10 min-h-[90vh] flex items-center justify-center p-6">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2 text-2xl no-underline group">
          <span class="w-10 h-10 rounded-xl bg-cyan-500/15 flex items-center justify-center text-xl group-hover:bg-cyan-500/25 transition">⚡</span>
          <span class="gradient-text font-extrabold">API 中转站</span>
        </a>
        <p class="text-sm text-slate-400 mt-3">欢迎回来</p>
      </div>

      <div class="glass-card rounded-2xl p-6">
        <% if (typeof error !== 'undefined' && error) { %>
        <div class="p-3 bg-red-500/10 border border-red-500/20 rounded-xl text-sm text-red-400 mb-4"><%= error %></div>
        <% } %>

        <form method="POST" action="/login" class="space-y-4">
          <div>
            <label class="block text-xs text-slate-400 mb-1.5 ml-1">邮箱</label>
            <input name="email" type="email" placeholder="your@email.com" required class="w-full px-4 py-3 bg-slate-900/50 border border-slate-700/50 rounded-xl text-slate-200 text-sm placeholder-slate-500 outline-none focus:border-cyan-500/50 focus:ring-2 focus:ring-cyan-500/10 transition backdrop-blur">
          </div>
          <div>
            <label class="block text-xs text-slate-400 mb-1.5 ml-1">密码</label>
            <input name="password" type="password" placeholder="输入密码" required class="w-full px-4 py-3 bg-slate-900/50 border border-slate-700/50 rounded-xl text-slate-200 text-sm placeholder-slate-500 outline-none focus:border-cyan-500/50 focus:ring-2 focus:ring-cyan-500/10 transition backdrop-blur">
          </div>
          <button class="btn-glow w-full py-3 bg-gradient-to-r from-cyan-500 to-blue-500 text-white rounded-xl font-bold text-sm hover:from-cyan-400 hover:to-blue-400 transition cursor-pointer shadow-xl shadow-cyan-500/25">登录</button>
        </form>

        <div class="flex items-center justify-between mt-5 pt-4 border-t border-slate-800/50">
          <p class="text-sm text-slate-500">
            没有账号？<a href="/register" class="text-cyan-400 hover:text-cyan-300 transition font-medium">注册</a>
          </p>
          <a href="/forgot-password" class="text-xs text-slate-500 hover:text-slate-400 transition">忘记密码？</a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<button id="backToTop" class="fixed bottom-8 right-8 w-12 h-12 bg-cyan-500/20 border border-cyan-500/30 text-cyan-400 rounded-full shadow-lg hover:bg-cyan-500/30 transition-all duration-200 opacity-0 pointer-events-none cursor-pointer flex items-center justify-center z-50 backdrop-blur text-lg">↑</button>

<script>
const btn = document.getElementById('backToTop');
window.addEventListener('scroll', () => {
  const v = window.scrollY > 400;
  btn.style.opacity = v ? '1' : '0';
  btn.style.pointerEvents = v ? 'auto' : 'none';
});
btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>
</body>
</html>
