<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="API 中转站 — 一个 Key 调用 DeepSeek · 通义千问 · 智谱 · Kimi · Grok · Claude 等大模型，兼容 OpenAI / Claude 格式，完全免费">
<title><%= title %></title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%2306B6D4'><path d='M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z'/></svg>">
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="/style.css">
</head>
<body class="text-slate-100 bg-[#030712]">

<%- include('partials/nav', { currentPage: 'home', user: typeof user !== 'undefined' ? user : null }) %>

<!-- ── Hero ── -->
<section class="hero-bg relative overflow-hidden border-b border-slate-800/50">
  <div class="relative z-10 max-w-5xl mx-auto px-6 py-24 md:py-36 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-xs font-medium mb-8 backdrop-blur">
      <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
      完全免费 · 无需付费 · 持续更新
    </div>
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight">
      一个 Key<br class="md:hidden">
      <span class="gradient-text">调用所有大模型</span>
    </h1>
    <p class="text-slate-400 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed">
      兼容 OpenAI / Claude 双格式，智能路由 + 自动故障转移<br class="hidden md:block">
      无需自建，注册即用，让你的应用零成本接入 AI
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="/register" class="btn-glow inline-flex items-center gap-2 px-8 py-3.5 bg-gradient-to-r from-cyan-500 to-blue-500 text-white rounded-xl font-bold text-sm hover:from-cyan-400 hover:to-blue-400 transition shadow-xl shadow-cyan-500/25 no-underline">
        免费注册 <span class="text-lg">→</span>
      </a>
      <a href="/docs" class="inline-flex items-center gap-2 px-8 py-3.5 border border-slate-600/50 text-slate-300 rounded-xl font-semibold text-sm hover:border-cyan-500/50 hover:text-cyan-400 hover:bg-cyan-500/5 transition no-underline backdrop-blur">
        查看文档
      </a>
    </div>

    <!-- terminal preview -->
    <div class="mt-12 max-w-xl mx-auto">
      <div class="glass-card rounded-2xl p-5 text-left">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/60"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/60"></span>
          <span class="text-xs text-slate-500 ml-2 font-mono">terminal</span>
        </div>
        <pre class="text-xs md:text-sm text-slate-300 font-mono leading-relaxed overflow-x-auto"><span class="text-slate-500"># 替换 YOUR_TOKEN 即可使用</span>
curl <span class="text-cyan-400">https://你的域名</span>/v1/chat/completions \
  -H <span class="text-green-400">"Authorization: Bearer YOUR_TOKEN"</span> \
  -d <span class="text-yellow-400">'{
  "model": "deepseek-chat",
  "messages": [{"role":"user","content":"你好"}]
}'</span></pre>
      </div>
    </div>
  </div>
</section>

<!-- ── Stats ── -->
<div class="max-w-2xl mx-auto px-4 -mt-6 relative z-20">
  <div class="grid grid-cols-3 gap-4">
    <div class="stat-card">
      <div class="text-2xl font-extrabold gradient-text"><%= models.length %></div>
      <div class="text-xs text-slate-400 mt-1">可用模型</div>
    </div>
    <div class="stat-card">
      <div class="text-2xl font-extrabold text-green-400">免费</div>
      <div class="text-xs text-slate-400 mt-1">零成本接入</div>
    </div>
    <div class="stat-card">
      <div class="text-2xl font-extrabold text-purple-400">双协议</div>
      <div class="text-xs text-slate-400 mt-1">OpenAI + Claude</div>
    </div>
  </div>
</div>

<main class="max-w-6xl mx-auto px-4 sm:px-6 mt-16">

  <!-- ── Features (bento) ── -->
  <section class="mb-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-3">为什么选择<span class="gradient-text">我们</span></h2>
      <p class="text-slate-400 text-sm">简单、快速、免费</p>
    </div>
    <div class="bento-grid">
      <div class="bento-card">
        <div class="feature-icon cyan">🔄</div>
        <h3 class="font-bold text-lg mb-2">双格式兼容</h3>
        <p class="text-sm text-slate-400 leading-relaxed">同时支持 OpenAI Chat Completions 和 Anthropic Messages 格式，ChatBox / NextChat / Cursor 等所有客户端即插即用</p>
      </div>
      <div class="bento-card">
        <div class="feature-icon purple">⚖️</div>
        <h3 class="font-bold text-lg mb-2">智能路由</h3>
        <p class="text-sm text-slate-400 leading-relaxed">加权负载均衡 + 自动故障转移，单个渠道挂了自动切到备用渠道，保证服务高可用</p>
      </div>
      <div class="bento-card">
        <div class="feature-icon green">⚡</div>
        <h3 class="font-bold text-lg mb-2">流式响应</h3>
        <p class="text-sm text-slate-400 leading-relaxed">完整支持 SSE 流式输出，首 Token 延迟低至 200ms，体验丝滑流畅</p>
      </div>
    </div>
  </section>

  <!-- ── Model Marquee ── -->
  <section class="mb-20">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold mb-2">接入 <span class="gradient-text">40+</span> 模型</h2>
      <p class="text-slate-400 text-sm">覆盖国内外主流大模型，持续接入中</p>
    </div>
    <div class="model-scroll mb-6">
      <div class="model-track">
        <% const shown = []; models.forEach(m => { if (!shown.includes(m.id)) { shown.push(m.id); %>
        <span class="model-chip"><%= m.id %></span>
        <% }}); %>
        <!-- duplicate for seamless loop -->
        <% shown.forEach(id => { %>
        <span class="model-chip"><%= id %></span>
        <% }); %>
      </div>
    </div>
    <p class="text-center">
      <a href="/models" class="inline-flex items-center gap-1 text-sm text-cyan-400 hover:text-cyan-300 transition">
        查看全部模型 <span>→</span>
      </a>
    </p>
  </section>

  <!-- ── Quickstart ── -->
  <section id="quickstart" class="mb-20 scroll-mt-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-3">三步<span class="gradient-text">接入</span></h2>
      <p class="text-slate-400 text-sm">一分钟完成接入</p>
    </div>
    <div class="step-connector max-w-3xl mx-auto mb-10">
      <div class="step-item">
        <div class="w-12 h-12 rounded-full bg-cyan-500/15 border border-cyan-500/30 text-cyan-400 flex items-center justify-center font-bold mx-auto mb-4 text-lg">1</div>
        <h3 class="font-bold mb-2">注册获取 Key</h3>
        <p class="text-xs text-slate-400">免费注册，立即获得 API Key</p>
      </div>
      <div class="step-item">
        <div class="w-12 h-12 rounded-full bg-purple-500/15 border border-purple-500/30 text-purple-400 flex items-center justify-center font-bold mx-auto mb-4 text-lg">2</div>
        <h3 class="font-bold mb-2">替换 Base URL</h3>
        <p class="text-xs text-slate-400">把 API 地址改成中转站地址</p>
      </div>
      <div class="step-item">
        <div class="w-12 h-12 rounded-full bg-green-500/15 border border-green-500/30 text-green-400 flex items-center justify-center font-bold mx-auto mb-4 text-lg">3</div>
        <h3 class="font-bold mb-2">像官方一样调用</h3>
        <p class="text-xs text-slate-400">OpenAI / Claude SDK 直接调用</p>
      </div>
    </div>
    <p class="text-center text-slate-500 text-xs">
      支持所有 OpenAI 兼容客户端 · base_url 改成 <code class="text-cyan-400 bg-slate-800/50 px-2 py-1 rounded-lg font-mono">你的域名/v1</code> 即可
    </p>
  </section>

  <!-- ── Tools ── -->
  <section id="tools" class="mb-20 scroll-mt-20">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold mb-3">免费<span class="gradient-text">工具箱</span></h2>
      <p class="text-slate-400 text-sm"><%= tools.length %> 个实用工具，全部免费使用</p>
    </div>

    <!-- search -->
    <div class="max-w-md mx-auto mb-8">
      <div class="relative">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="search" class="w-full pl-10 pr-10 py-3 text-sm bg-slate-900/60 border border-slate-700/50 rounded-xl text-slate-200 placeholder-slate-500 outline-none focus:border-cyan-500/50 focus:ring-2 focus:ring-cyan-500/10 transition backdrop-blur" type="text" placeholder="搜索工具..." autocomplete="off">
        <button id="searchClear" class="absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-600 hover:text-slate-400 transition hidden cursor-pointer">✕</button>
      </div>
    </div>

    <!-- category tabs -->
    <div class="flex justify-center gap-2 mb-8 flex-wrap" id="categoryTabs">
      <% categories.forEach((cat, i) => { %>
        <button class="category-tab px-4 py-2 rounded-full text-xs font-medium transition cursor-pointer border <%= i === 0 ? 'bg-cyan-500/10 text-cyan-400 border-cyan-500/30' : 'text-slate-400 border-slate-700/50 hover:text-slate-200 hover:border-slate-600 bg-transparent' %>" data-category="<%= cat %>"><%= cat %></button>
      <% }) %>
    </div>

    <p class="text-center text-slate-500 text-xs mb-8">共 <span id="countNum"><%= tools.length %></span> 个工具</p>

    <!-- tool cards -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4" id="toolGrid">
      <% tools.forEach((tool, i) => { %>
        <a href="<%= tool.url %>" class="tool-card-new group" data-category="<%= tool.category %>" data-name="<%= tool.name %>" data-desc="<%= tool.desc %>">
          <div class="flex items-start gap-3">
            <div class="tool-icon-wrap w-10 h-10 rounded-xl bg-slate-800/50 flex items-center justify-center text-lg shrink-0 transition-colors"><%- tool.icon %></div>
            <div class="min-w-0">
              <h3 class="text-sm font-semibold text-white group-hover:text-cyan-400 transition-colors truncate"><%= tool.name %></h3>
              <p class="text-xs text-slate-400 mt-1 line-clamp-2 leading-relaxed"><%= tool.desc %></p>
              <% if (tool.badge) { %>
                <span class="inline-block mt-2 px-2 py-0.5 bg-cyan-500/10 text-cyan-400 text-[10px] rounded-md border border-cyan-500/20"><%= tool.badge %></span>
              <% } %>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
    <div id="noResults" class="text-center text-slate-500 py-20 hidden">
      <div class="text-4xl mb-3">🔍</div>
      <p>没有匹配的工具</p>
    </div>
  </section>

</main>

<%- include('partials/footer') %>

<button id="backToTop" class="fixed bottom-8 right-8 w-12 h-12 bg-cyan-500/20 border border-cyan-500/30 text-cyan-400 rounded-full shadow-lg hover:bg-cyan-500/30 transition-all duration-200 opacity-0 pointer-events-none cursor-pointer flex items-center justify-center z-50 backdrop-blur text-lg">↑</button>

<script>
const btn = document.getElementById('backToTop');
window.addEventListener('scroll', () => {
  const v = window.scrollY > 400;
  btn.style.opacity = v ? '1' : '0';
  btn.style.pointerEvents = v ? 'auto' : 'none';
});
btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

const search = document.getElementById('search');
const clearBtn = document.getElementById('searchClear');
const cards = document.querySelectorAll('.tool-card-new');
const noResults = document.getElementById('noResults');
const countNum = document.getElementById('countNum');
const categoryTabs = document.querySelectorAll('.category-tab');
let activeCat = '全部';

function updateClear() { clearBtn.style.display = search.value ? 'flex' : 'none'; }
function filter() {
  const q = search.value.toLowerCase();
  let visible = 0;
  cards.forEach(c => {
    const matchCat = activeCat === '全部' || c.dataset.category === activeCat;
    const matchSearch = !q || c.dataset.name.toLowerCase().includes(q) || c.dataset.desc.toLowerCase().includes(q);
    c.style.display = (matchCat && matchSearch) ? '' : 'none';
    if (matchCat && matchSearch) visible++;
  });
  countNum.textContent = visible;
  noResults.style.display = visible === 0 ? '' : 'none';
}
search.addEventListener('input', () => { updateClear(); filter(); });
clearBtn.addEventListener('click', () => { search.value = ''; updateClear(); filter(); search.focus(); });
categoryTabs.forEach(tab => {
  tab.addEventListener('click', () => {
    activeCat = tab.dataset.category;
    categoryTabs.forEach(t => {
      t.className = t.dataset.category === activeCat ? 'category-tab px-4 py-2 rounded-full text-xs font-medium transition cursor-pointer border bg-cyan-500/10 text-cyan-400 border-cyan-500/30' : 'category-tab px-4 py-2 rounded-full text-xs font-medium transition cursor-pointer border text-slate-400 border-slate-700/50 hover:text-slate-200 hover:border-slate-600 bg-transparent';
    });
    filter();
  });
});
</script>
</body>
</html>
